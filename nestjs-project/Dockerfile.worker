FROM node:25.6.0-slim

# ffmpeg ships both `ffmpeg` and `ffprobe` — the worker shells out to them via
# child_process (TD-05: no fluent-ffmpeg wrapper).
RUN apt update && apt install -y procps curl ffmpeg

WORKDIR /home/node/app

USER node

# Consumes the pg-boss `video-process` queue (TD-04). node_modules is provided
# via the mounted volume (shared with the API) — run `npm install` once on the
# API service first, as documented in the README.
CMD [ "npm", "run", "start:worker:dev" ]
